# Database Configuration - Use Supabase Connection String
# Get from: Supabase Dashboard → Settings → Database → Connection pooling (Use port 6543)
DATABASE_URL=postgresql://postgres.[PROJECT_ID]:[PASSWORD]@aws-1-ap-southeast-1.pooler.supabase.com:6543/postgres

# Meta (WhatsApp Cloud API) Configuration
# Get from: Meta for Developers → App Dashboard → WhatsApp → API Setup
META_PHONE_NUMBER_ID=your_phone_number_id
META_VERIFY_TOKEN=your_custom_webhook_verify_token
META_API_VERSION=v25.0
WHATSAPP_ACCESS_TOKEN=your_system_user_access_token
META_APP_SECRET=your_meta_app_secret

# Admin Authentication
ADMIN_PASSWORD_HASH=your_admin_password_hash
ADMIN_USERNAME=admin

# Application URL
APP_URL=http://localhost:3000

# Environment
NODE_ENV=development
