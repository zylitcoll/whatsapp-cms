---
import Layout from '@/layouts/Layout.astro';
import ContactList from '@/components/ContactList';
import ChatWindow from '@/components/ChatWindow';
import TemplateManager from '@/components/TemplateManager';
import CannedResponses from '@/components/CannedResponses';
import DashboardStats from '@/components/DashboardStats';

// Check if user is logged in
const sessionToken = Astro.cookies.get('session_token');
if (!sessionToken) {
  return Astro.redirect('/');
}
---

<Layout title="Dashboard - WhatsApp CMS">
  <div class="min-h-screen bg-gray-900">
    <nav class="bg-gray-800 border-b border-gray-700 p-4 sticky top-0 z-50">
      <div class="max-w-7xl mx-auto flex items-center justify-between">
        <div class="flex items-center gap-3">
          <h1 class="text-2xl font-bold text-green-500">📱 WhatsApp CMS</h1>
        </div>
        <div class="flex items-center gap-4">
          <span class="text-gray-300">👤 Admin</span>
          <button
            id="logoutBtn"
            class="px-4 py-2 bg-red-600 hover:bg-red-700 text-white rounded-lg transition font-semibold text-sm"
          >
            Logout
          </button>
        </div>
      </div>
    </nav>

    <!-- App Wrapper handled by Astro Islands -->
    <div id="react-app-wrapper" data-session={sessionToken.value}>
      <div class="max-w-7xl mx-auto p-6">
        <DashboardStats client:load sessionToken={sessionToken.value} />

        <div class="mt-6 grid grid-cols-1 lg:grid-cols-3 gap-6">
          <div class="lg:col-span-1 bg-gray-800 rounded-lg border border-gray-700 overflow-hidden flex flex-col h-[600px]">
            <div class="p-4 border-b border-gray-700 bg-gray-700">
              <h2 class="text-lg font-bold text-white">Conversations</h2>
            </div>
            <div class="flex-1 overflow-y-auto" id="contact-list-container">
              <!-- Will be mounted by script -->
            </div>
          </div>

          <div class="lg:col-span-2 flex flex-col gap-6">
            <div class="bg-gray-800 rounded-lg border border-gray-700 overflow-hidden h-[400px]" id="chat-window-container">
               <!-- Will be mounted by script -->
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
              <TemplateManager client:load sessionToken={sessionToken.value} />
              <CannedResponses client:load sessionToken={sessionToken.value} />
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</Layout>

<script>
  import React from 'react';
  import { createRoot } from 'react-dom/client';
  import ContactList from '@/components/ContactList';
  import ChatWindow from '@/components/ChatWindow';

  // Handle logout
  const logoutBtn = document.getElementById('logoutBtn');
  const sessionToken = document.getElementById('react-app-wrapper')?.dataset.session;
  
  logoutBtn?.addEventListener('click', async () => {
    if (sessionToken) {
      await fetch('/api/auth/logout', {
        method: 'POST',
        headers: { 'x-session-token': sessionToken },
      });
    }
    localStorage.removeItem('session_token');
    document.cookie = 'session_token=; Max-Age=0; path=/;';
    window.location.href = '/';
  });

  // Render interconnected React components
  const contactContainer = document.getElementById('contact-list-container');
  const chatContainer = document.getElementById('chat-window-container');

  if (contactContainer && chatContainer && sessionToken) {
    // Shared state management for Vanilla JS <-> React integration
    let currentContact = null;
    let chatRoot = createRoot(chatContainer);
    let contactRoot = createRoot(contactContainer);

    const renderChat = (contact) => {
      chatRoot.render(
        React.createElement(ChatWindow, {
          contact: contact,
          sessionToken: sessionToken
        })
      );
    };

    const handleContactSelect = (contact) => {
      currentContact = contact;
      renderChat(contact);
    };

    contactRoot.render(
      React.createElement(ContactList, {
        sessionToken: sessionToken,
        onSelectContact: handleContactSelect,
        selectedContactId: currentContact?.id
      })
    );
    
    // Initial render for chat
    renderChat(null);
  }
</script>
