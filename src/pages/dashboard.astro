---
import Layout from '@/layouts/Layout.astro';
import ContactList from '@/components/ContactList';
import ChatWindow from '@/components/ChatWindow';
import TemplateManager from '@/components/TemplateManager';
import CannedResponses from '@/components/CannedResponses';
import DashboardStats from '@/components/DashboardStats';

// Check if user is logged in
const sessionToken = Astro.cookies.get('session_token');
if (!sessionToken) {
  return Astro.redirect('/');
}
---

<Layout title="Dashboard - WhatsApp CMS">
  <div class="min-h-screen bg-gray-900">
    <nav class="bg-gray-800 border-b border-gray-700 p-4 sticky top-0 z-50">
      <div class="max-w-7xl mx-auto flex items-center justify-between">
        <div class="flex items-center gap-3">
          <h1 class="text-2xl font-bold text-green-500">📱 WhatsApp CMS</h1>
        </div>
        <div class="flex items-center gap-4">
          <span class="text-gray-300">👤 Admin</span>
          <button
            id="logoutBtn"
            class="px-4 py-2 bg-red-600 hover:bg-red-700 text-white rounded-lg transition font-semibold text-sm"
          >
            Logout
          </button>
        </div>
      </div>
    </nav>

    <!-- React App Wrapper -->
    <div id="react-app-root" data-session={sessionToken.value}></div>
  </div>
</Layout>

<script>
  // Handle logout
  const logoutBtn = document.getElementById('logoutBtn');
  const sessionToken = document.getElementById('react-app-root')?.dataset.session;
  
  logoutBtn?.addEventListener('click', async () => {
    if (sessionToken) {
      await fetch('/api/auth/logout', {
        method: 'POST',
        headers: { 'x-session-token': sessionToken },
      });
    }
    localStorage.removeItem('session_token');
    document.cookie = 'session_token=; Max-Age=0; path=/;';
    window.location.href = '/';
  });
</script>

<script>
  import React, { useState } from 'react';
  import { createRoot } from 'react-dom/client';
  import ContactList from '@/components/ContactList';
  import ChatWindow from '@/components/ChatWindow';
  import DashboardStats from '@/components/DashboardStats';
  import TemplateManager from '@/components/TemplateManager';
  import CannedResponses from '@/components/CannedResponses';

  const App = () => {
    const sessionToken = document.getElementById('react-app-root')?.dataset.session || '';
    const [selectedContact, setSelectedContact] = useState(null);

    return (
      <div className="max-w-7xl mx-auto p-6">
        <DashboardStats sessionToken={sessionToken} />

        <div className="mt-6 grid grid-cols-1 lg:grid-cols-3 gap-6">
          <div className="lg:col-span-1 bg-gray-800 rounded-lg border border-gray-700 overflow-hidden flex flex-col h-[600px]">
            <div className="p-4 border-b border-gray-700 bg-gray-700">
              <h2 className="text-lg font-bold text-white">Conversations</h2>
            </div>
            <div className="flex-1 overflow-y-auto">
              <ContactList 
                sessionToken={sessionToken} 
                onSelectContact={setSelectedContact}
                selectedContactId={selectedContact?.id}
              />
            </div>
          </div>

          <div className="lg:col-span-2 flex flex-col gap-6">
            <div className="bg-gray-800 rounded-lg border border-gray-700 overflow-hidden h-[400px]">
              <ChatWindow 
                contact={selectedContact} 
                sessionToken={sessionToken} 
              />
            </div>

            <div className="grid grid-cols-1 md:grid-cols-2 gap-4">
              <TemplateManager sessionToken={sessionToken} />
              <CannedResponses sessionToken={sessionToken} />
            </div>
          </div>
        </div>
      </div>
    );
  };

  const rootEl = document.getElementById('react-app-root');
  if (rootEl) {
    const root = createRoot(rootEl);
    root.render(<App />);
  }
</script>
